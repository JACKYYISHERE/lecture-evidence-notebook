{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lecture Bundle Manifest",
  "type": "object",
  "required": ["course", "lecture", "created_at", "files"],
  "properties": {
    "course": { "type": "string" },
    "lecture": { "type": "string" },
    "lecture_date": { "type": "string" },
    "source_url": { "type": "string" },
    "created_at": { "type": "string" },
    "duration": { "type": "string" },
    "notes": { "type": "string" },
    "files": {
      "type": "object",
      "properties": {
        "recording": { "type": "string" },
        "audio": { "type": "string" },
        "transcript_vtt": { "type": "string" },
        "transcript_md": { "type": "string" },
        "slides": { "type": "string" },
        "smart_summary": { "type": "string" },
        "smart_chapters": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

